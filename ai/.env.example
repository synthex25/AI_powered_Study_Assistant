# MindRAG Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Settings
# =============================================================================
# Provider: "deepinfra", "openai", "ollama", "gemini", "bedrock"
LLM_PROVIDER=bedrock

# Model name (depends on provider)
# DeepInfra: meta-llama/Llama-3.3-70B-Instruct-Turbo
# OpenAI: gpt-4o-mini, gpt-4o
# Ollama: llama3.2:latest
# Gemini: gemini-2.5-flash, gemini-2.5-pro
# Bedrock: anthropic.claude-3-sonnet-20240229-v1:0
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# =============================================================================
# API Keys
# =============================================================================
DEEPINFRA_API_KEY=your_deepinfra_key_here
OPENAI_API_KEY=your_openai_key_here

# Ollama (for local models)
OLLAMA_HOST=http://localhost:11434

# Google Gemini
GOOGLE_API_KEY=your_google_api_key

# AWS Bedrock (uses AWS credentials from environment or ~/.aws/credentials)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# =============================================================================
# External Services (Optional)
# =============================================================================

YOUTUBE_API_KEY = ""
GOOGLE_SEARCH_API_KEY = ""
GOOGLE_CSE_ID = ""
# =============================================================================
# JWT Authentication (MUST match Node.js backend)
# =============================================================================
# Use the SAME JWT_SECRET as your Node.js backend for token validation
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=false
CHROMA_PERSIST_DIR=./chroma_db

# =============================================================================
# Storage Provider Settings
# =============================================================================
# Provider: "s3" or "local"
# - s3: Use AWS S3 for file storage (requires AWS credentials)
# - local: Use local filesystem (default, good for development)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./application-data

# S3 Configuration (only needed if STORAGE_PROVIDER=s3)
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# LLM_PROVIDER=bedrock
# LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
# # Uses AWS credentials from env or ~/.aws/credentials

# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
